# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Names only — no secrets in this file.

# Public base URL of this deployment, scheme + host, no trailing slash
# (e.g. https://your-app.vercel.app). Used to build the magic-link redirect so
# it points at the deployed domain, not localhost. Leave blank in local dev —
# the origin is then derived from the request. Must also be set as the Supabase
# Site URL and allowlisted in Auth -> URL Configuration -> Redirect URLs.
NEXT_PUBLIC_SITE_URL=

# Supabase project URL and keys (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email provider for the daily brief
RESEND_API_KEY=

# LLM provider for the async capture classifier
ANTHROPIC_API_KEY=

# OpenAI — voice transcription (gpt-4o-mini-transcribe). Separate from the
# classifier above.
OPENAI_API_KEY=
# Optional: override the transcription model. Defaults to gpt-4o-mini-transcribe;
# set to gpt-4o-transcribe for stronger domain-vocabulary recognition.
TRANSCRIPTION_MODEL=
# Optional: receipt OCR vision model. Defaults to gpt-4o-mini; set to gpt-4o if
# it misreads real receipts.
RECEIPT_VISION_MODEL=

# Google Calendar OAuth (read-only). Create a Web-application OAuth client in
# Google Cloud (Calendar API enabled, consent screen "In production"); add
# <site>/api/calendar/callback + http://localhost:3000/api/calendar/callback as
# authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 32-byte AES key (base64) for encrypting stored calendar tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CALENDAR_TOKEN_KEY=
