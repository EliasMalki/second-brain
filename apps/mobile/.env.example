# Public Supabase config, inlined into the JS bundle at build time.
# Same project as apps/web; values are the anon (publishable) key — safe on-device.
# Copy to .env and fill in. Names use the EXPO_PUBLIC_ prefix (vs web's NEXT_PUBLIC_).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Web app origin the app POSTs captures to (text/voice/receipt run server-side).
# Dev: your Mac's LAN IP running `npm run dev` (e.g. http://192.168.1.20:3000).
# Prod: the deployed web URL.
EXPO_PUBLIC_API_URL=http://YOUR-MAC-LAN-IP:3000
