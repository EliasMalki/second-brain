# Public Supabase config, inlined into the JS bundle at build time.
# Same project as apps/web; values are the anon (publishable) key — safe on-device.
# Copy to .env and fill in. Names use the EXPO_PUBLIC_ prefix (vs web's NEXT_PUBLIC_).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
