{
  "expo": {
    "name": "Servo",
    "slug": "servo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "servo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.malkel.servo",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.malkel.servo",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "backgroundColor": "#fafafa",
          "dark": {
            "backgroundColor": "#111113"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to record voice notes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to attach receipt photos.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to photograph receipts."
        }
      ],
      [
        "expo-font",
        {
          "ios": {
            "fonts": [
              "./assets/fonts/Geist-Regular.ttf",
              "./assets/fonts/Geist-Medium.ttf",
              "./assets/fonts/Geist-SemiBold.ttf",
              "./assets/fonts/Geist-Bold.ttf"
            ]
          },
          "android": {
            "fonts": [
              {
                "fontFamily": "Geist",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Geist-Regular.ttf", "weight": 400 }
                ]
              },
              {
                "fontFamily": "Geist Medium",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Geist-Medium.ttf", "weight": 500 }
                ]
              },
              {
                "fontFamily": "Geist SemiBold",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Geist-SemiBold.ttf", "weight": 600 }
                ]
              },
              {
                "fontFamily": "Geist Bold",
                "fontDefinitions": [
                  { "path": "./assets/fonts/Geist-Bold.ttf", "weight": 700 }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
