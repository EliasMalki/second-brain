{
  "name": "second-brain",
  "version": "0.5.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "npm run start -w web",
    "lint": "npm run lint -w web",
    "tokens": "node packages/shared/scripts/generate-tokens.mjs",
    "tokens:check": "node packages/shared/scripts/generate-tokens.mjs --check",
    "typecheck": "npm run tokens:check && npm run typecheck --workspaces --if-present"
  }
}
