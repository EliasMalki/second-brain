{
  "compilerOptions": {
    "target": "ES2022",
    // Unlike packages/shared this package IS allowed the DOM lib — CodeMirror
    // is browser-native. It still must not import react-dom, next/*, or
    // react-native: core is plain TS, src/web holds the one React wrapper.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
