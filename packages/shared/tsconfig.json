{
  "compilerOptions": {
    "target": "ES2022",
    // Deliberately NO "dom" lib: window/document/localStorage/indexedDB must be
    // type errors here. "node" types supply fetch/process for server runtimes.
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"]
}
